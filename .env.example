# 大语言模型（OpenAI 兼容接口）— 复制为 .env 后填写
# 设置 VITE_LLM_MODEL 后，应用内「系统设置」将只读展示，以 .env 为准

# 接口地址（Ollama 本地示例见下）
VITE_LLM_BASE_URL=https://api.deepseek.com/v1

# API 密钥（Ollama 可填 ollama 或任意占位）
VITE_LLM_API_KEY=

# 模型名称（须支持 Tool Call）
VITE_LLM_MODEL=deepseek-chat

# --- 本地 Ollama 示例 ---
# VITE_LLM_BASE_URL=http://localhost:11434/v1
# VITE_LLM_API_KEY=ollama
# VITE_LLM_MODEL=llama3.2
