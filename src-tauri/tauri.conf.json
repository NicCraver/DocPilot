{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocPilot",
  "version": "0.1.1",
  "identifier": "dev.docpilot.app",
  "build": {
    "beforeDevCommand": "vp dev",
    "beforeBuildCommand": "vp build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DocPilot",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
