{
  "name": "docpilot",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "check": "vue-tsc --noEmit",
    "icons:build": "node scripts/prepare-app-icon.mjs && tauri icon src-tauri/app-icon.png -o src-tauri/icons && node scripts/prepare-app-icon.mjs --icns-only",
    "markitdown:install": "node scripts/ensure-markitdown.mjs",
    "build:sidecar": "node scripts/run-build-sidecar.mjs",
    "dmg:background": "node scripts/generate-dmg-background.mjs",
    "tauri:build": "pnpm run build && pnpm run build:sidecar && node scripts/tauri-release-build.mjs",
    "tauri:build:dev": "pnpm run build && npx tauri build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@docpilot/shared-types": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@vueuse/core": "^11.0.0",
    "ai": "^6.0.194",
    "markstream-vue": "^1.0.0",
    "vue": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@tauri-apps/cli": "^2.11.2",
    "@unocss/preset-icons": "^66.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "unocss": "^66.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.1.0"
  },
  "packageManager": "pnpm@11.5.1"
}
