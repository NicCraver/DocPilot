{
  "name": "docpilot",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "test": "vp test",
    "check": "vp check src packages/shared-types/src/index.ts packages/shared-types/src/tool-ids.ts",
    "icons:build": "node scripts/prepare-app-icon.mjs && tauri icon src-tauri/app-icon.png -o src-tauri/icons && node scripts/prepare-app-icon.mjs --icns-only",
    "markitdown:install": "node scripts/ensure-markitdown.mjs",
    "word-typeset:install": "node scripts/ensure-word-typeset.mjs",
    "word-smart-doc:install": "node scripts/ensure-word-typeset.mjs && node scripts/ensure-libreoffice.mjs",
    "word-smart-doc:make-fixtures": "node -e \"const{spawnSync}=require('node:child_process');const p=process.platform==='win32'?'.venv/Scripts/python.exe':'.venv/bin/python3';process.exit(spawnSync(p,['scripts/word-smart-doc-test-data/make-fixtures.py'],{stdio:'inherit'}).status||0)\"",
    "word-smart-doc:learn-test": "node scripts/run-word-smart-doc-learn-test.mjs",
    "word-smart-doc:adaptive-test": "node scripts/run-word-smart-doc-adaptive-test.mjs",
    "word-smart-doc:style-test": "node scripts/run-word-smart-doc-style-test.mjs",
    "word-smart-doc:e2e": "node scripts/run-word-smart-doc-e2e.mjs",
    "word-template:test": "node scripts/run-word-template-test.mjs",
    "word-typeset:test": "node scripts/run-word-typeset-tests.mjs",
    "word-typeset:gov-report": "node scripts/run-government-report-test.mjs",
    "word-typeset:thesis-test": "node scripts/run-thesis-test.mjs",
    "word-typeset:journal-test": "node scripts/run-journal-test.mjs",
    "word-typeset:coal-paper-full": "node scripts/run-coal-paper-full.mjs",
    "build:sidecar": "node scripts/run-build-sidecar.mjs",
    "dmg:background": "node scripts/generate-dmg-background.mjs",
    "tauri:build": "pnpm run build && pnpm run build:sidecar && node scripts/tauri-release-build.mjs",
    "tauri:build:dev": "pnpm run build && npx tauri build",
    "ci:local": "bash scripts/ci-local.sh",
    "hooks:install": "bash scripts/install-git-hooks.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@docpilot/shared-types": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@vueuse/core": "^11.0.0",
    "ai": "^6.0.194",
    "markstream-vue": "^1.0.0",
    "vue": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@tauri-apps/cli": "^2.11.2",
    "@unocss/preset-icons": "^66.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "unocss": "^66.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.1.0"
  },
  "packageManager": "pnpm@11.5.1"
}
